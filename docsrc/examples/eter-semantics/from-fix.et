// ========================================================================
// ========================================================================
// Store Fix in Struct from Fix
// ========================================================================
// ========================================================================

// ==========
// SINGLE CASE
// ==========

struct Point {
    fix x: i32,
    fix y: i32,
}

fn fix f(fix p: Point): Point {
    let fix x = p.x;
    let fix y = p.y;
    Point { x, y }
}

fn tmp1() {
    let fix p1 = Point { x: 1, y: 2 };
    let fix p2 = f(p1);
}

// OPTIMIZATION: to avoid copy and reference counting
// fn tmp2() {
//     let fix p2;
//     let tmp = Point { x: 1, y: 2 };
//     {
//         let p1 = tmp;
//         p2 = f(p1);
//     }
// }
fn tmp2() {
    let fix p2;
    {
        let fix p1 = Point { x: 1, y: 2 };
        p2 = f(p1);
    }
}

// ==========
// Fix-Fix-Fix as return and formal parameters from Fix
// =========

struct Point {
    fix x: i32,
    fix y: i32,
}

fn fix f(fix p: Point, fix u: Point): Point {
    // u is not used
    let fix x = p.x;
    let fix y = p.y;
    Point { x, y }
}

fn tmp1() {
    let fix p1 = Point { x: 1, y: 2 };
    let fix p2 = Point { x: 3, y: 4 };
    let fix p2 = f(p1, p2);
}

// OPTIMIZATION: to avoid copy and reference counting
// fn tmp2() {
//     let p2;
//     let p = Point { x: 1, y: 2 };
//     let tmp = Point { x: 3, y: 4 };
//     {
//         let u = tmp;
//         p2 = f(p, tmp);
//     }
// }
fn tmp2() {
    let fix p2;
    let fix p = Point { x: 1, y: 2 };
    {
        let fix u = Point { x: 3, y: 4 };
        p2 = f(p, u);
    }
}



// ==========
// Fix-Fix-Mut as return and formal parameters from Fix
// =========

struct Point {
    fix x: i32,
    fix y: i32,
}

fn fix f(fix p: Point, mut u: Point): Point {
    // u is not used
    let fix x = p.x;
    let fix y = p.y;
    Point { x, y }
}

fn tmp1() {
    let fix p1 = Point { x: 1, y: 2 };
    let mut p2 = Point { x: 1, y: 2 };
    let fix p3 = f(p1, p2);
    // - p2 is moved, so it is not used anymore
    // - p1 can be used again
}


// OPTIMIZATION to avoid copy and reference counting
// fn tmp2() {
//     let p3;
//     let p1 = Point { x: 1, y: 2 };
//     let mut tmp = Point { x: 3, y: 4 };
//     {
//         let mut p2 = tmp;
//         p3 = f(p1, p2);
//     }
// }
fn tmp2() {
    let fix p3;
    let fix p1 = Point { x: 1, y: 2 };
    {
        let mut p2 = Point { x: 3, y: 4 };
        p3 = f(p1, p2);
        // - p2 is moved, so it is not used anymore
        // - p1 can be used again
    }
}

// ==========
// Fix-Fix-Proj as return and formal parameters from Fix
// =========


struct Point {
    fix x: i32,
    fix y: i32,
}

fn fix f(fix p: Point, proj u: Point): Point {
    // u is not used
    let fix x = p.x;
    let fix y = p.y;
    &p.x = 10;
    &p.y = 20;
    Point { x, y }
}

fn tmp1() {
    let fix p1 = Point { x: 1, y: 2 };
    let mut p2 = Point { x: 1, y: 2 };
    let fix p3 = f(p1, &p2);
    // - p2 is projected, so it is can be used again
    // - p1 can be used again
}


// OPTIMIZATION to avoid copy and reference counting
// fn tmp2() {
//     let p3;
//     let p1 = Point { x: 1, y: 2 };
//     let mut tmp = Point { x: 3, y: 4 };
//     {
//         let mut p2 = tmp;
//         p3 = f(p1, p2);
//     }
// }
fn tmp2() {
    let fix p3;
    let fix p1 = Point { x: 1, y: 2 };
    {
        let mut p2 = Point { x: 3, y: 4 };
        p3 = f(p1, &p2);
        // - p2 is projected, so it is can be used again
        // - p1 can be used again
    }
}

