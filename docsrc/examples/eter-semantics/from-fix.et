// SINGLE CASE
// ==========

struct Point {
    mut x: i32,
    mut y: i32,
}

fn fix f(fix p: Point): Point {
    // let mut x = p.x; // ERROR: p is under the regime fix, it propagates to the whole struct.
    // let mut y = p.y; // ERROR: p is under the regime fix, it propagates to the whole struct.
    Point { x, y }
}

fn tmp1() {
    let fix p1 = Point { x: 1, y: 2 };
    let fix p2 = f(p1);
}

fn tmp2() {
    let fix p2;
    {
        let fix p1 = Point { x: 1, y: 2 };
        p2 = f(p1);
    }
}

