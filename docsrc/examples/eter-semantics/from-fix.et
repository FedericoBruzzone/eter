// Fix-Proj to Mut
// ==========
fn fix f(proj p: Point): Point {
    // p // ERROR: Escaping the return of a proj to a fix is not allowed. Need to copy.
}
fn main() {
    let proj p = &Point { x: 1, y: 2 };
    let fix q = f(&p);
}

fn fix f2(proj p1: Point, proj p2: Point): Point {
    p1 // ERROR: Escaping the return of a proj to a fix is not allowed. Need to copy.
}
fn main() {
    let proj p1 = &Point { x: 1, y: 2 };
    let proj p2 = &Point { x: 3, y: 4 };
    let fix q = f2(&p1, &p2);
}

