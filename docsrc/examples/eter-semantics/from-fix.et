// ========================================================================
// ========================================================================
// SCALAR TYPES
// ========================================================================
// ========================================================================


// ==========
// Fix to Fix
// ==========
fn f(fix x: i32) {}
fn main() {
    let fix x: i32 = 1;
    let fix y: i32 = x;
    f(x);
}

// ==========
// Fix to Mut
// ==========
fn f(mut x: i32) {}
fn main() {
    let fix x: i32 = 1;
    // let mut y: i32 = x; // ERROR: Changing the regime from fix to mut is not allowed. Need to copy.
    // f(x); // ERROR: Changing the regime from fix to mut is not allowed. Need to copy.
}

// ===========
// Fix to Proj
// ===========
fn f(proj x: i32) {}
fn main() {
    let x: i32 = 1;
    // let proj y: i32 = &x; // ERROR: Changing the regime from fix to proj is not allowed. Need to copy.
    // f(&x); // ERROR: Changing the regime from fix to proj is not allowed. Need to copy.
}

// ========================================================================
// ========================================================================
// ARRAY TYPES
// ========================================================================
// ========================================================================

// ==========
// Fix to Fix
// ==========
fn f(fix x: [i32; 3]) {}
fn main() {
    let fix x: [i32; 3] = [1, 2, 3];
    let fix y: [i32; 3] = x; // O(1)
    f(x); // O(1)
}

// ==========
// Fix to Mut
// ==========
fn f(mut x: [i32; 3]) {}
fn main() {
    let fix x: [i32; 3] = [1, 2, 3];
    // let mut y: [i32; 3] = x; // ERROR: Changing the regime from fix to mut is not allowed. Need to copy.
    // f(x); // ERROR: Changing the regime from fix to mut is not allowed. Need to copy.
}

// ===========
// Fix to Proj
// ===========
fn f(proj x: [i32; 3]) {}
fn main() {
    let fix x: [i32; 3] = [1, 2, 3];
    // let proj y: [i32; 3] = &x; // ERROR: Changing the regime from fix to proj is not allowed. Need to copy.
    // f(&x); // ERROR: Changing the regime from fix to proj is not allowed. Need to copy.
}

// ========================================================================
// ========================================================================
// Structs with Fix
// ========================================================================
// ========================================================================

struct Point {
    fix x: i32,
    fix y: i32,
}

// ==========
// Fix to Fix
// ==========
fn f(fix p: Point) {}
fn main() {
    let fix p = Point { x: 1, y: 2 };
    let fix q = p;
    f(p);
}

// ==========
// Fix to Mut
// ==========
fn f(mut p: Point) {}
fn main() {
    let fix p = Point { x: 1, y: 2 };
    // let mut q = p; // ERROR: Changing the regime from fix to mut is not allowed. Need to copy.
    // f(p); // ERROR: Changing the regime from fix to mut is not allowed. Need to copy.
}

// ===========
// Fix to Proj
// ===========
fn f(proj p: Point) {}
fn main() {
    let fix p = Point { x: 1, y: 2 };
    // let proj q = &p; // ERROR: Changing the regime from fix to proj is not allowed. Need to copy.
    // f(&p); // ERROR: Changing the regime from fix to proj is not allowed. Need to copy.
}

// ========================================================================
// ========================================================================
// Fix-Fix as return and formal parameter
// ========================================================================
// ========================================================================

// ==========
// Fix-Fix to Fix
// ==========
fn fix f(fix p: Point): Point { p }
fn main() {
    let fix p = Point { x: 1, y: 2 };
    let fix q = f(p);
}

fn fix f2(fix p1: Point, fix p2: Point): Point { p1 }
fn main() {
    let fix p1 = Point { x: 1, y: 2 };
    let fix p2 = Point { x: 3, y: 4 };
    let fix q = f2(p1, p2);
}

// ==========
// Fix-Fix to Mut
// ==========
fn fix f(fix p: Point): Point { p }
fn main() {
    let fix p = Point { x: 1, y: 2 };
    // let mut q = f(p); // ERROR: Changing the regime from fix to mut is not allowed. Need to copy.
}

fn fix f2(fix p1: Point, fix p2: Point): Point { p1 }
fn main() {
    let fix p1 = Point { x: 1, y: 2 };
    let fix p2 = Point { x: 3, y: 4 };
    // let mut q = f2(p1, p2); // ERROR: Changing the regime from fix to mut is not allowed. Need to copy.
}

